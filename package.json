{
  "name": "demo-unispace",
  "version": "1.0.0",
  "description": "UniSpace - Educational Platform for Students and Teachers",
  "private": true,
  "workspaces": [
    "admin/frontend",
    "admin/backend",
    "local/frontend",
    "local/backend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=local/backend\" \"npm run dev --workspace=local/frontend\"",
    "dev:all": "concurrently \"npm run dev --workspace=local/backend\" \"npm run dev --workspace=local/frontend\" \"npm run dev --workspace=admin/backend\" \"npm run dev --workspace=admin/frontend\"",
    "build": "npm run build --workspaces --if-present",
    "start": "npm start --workspace=local/backend",
    "local:server": "npm run dev --workspace=local/backend",
    "local:client": "npm run preview --workspace=local/frontend",
    "admin:server": "npm run dev --workspace=admin/backend",
    "admin:client": "npm run preview --workspace=admin/frontend",
    "db:migrate": "node database/migrations/runner.js",
    "db:seed": "node database/seeds/runner.js",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": "^24.0.0",
    "npm": ">=10.0.0"
  }
}
